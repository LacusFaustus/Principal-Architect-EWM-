<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <suppress checks=".*" files="target[\\/]generated-sources[\\/]"/>
    <suppress checks=".*" files="src[\\/]main[\\/]generated[\\/]"/>
    <suppress checks=".*" files=".*[\\/]proto[\\/].*\.java"/>
    <suppress checks=".*" files=".*[\\/]avro[\\/].*\.java"/>
    <suppress checks="Javadoc.*" files=".*\.java"/>
    <suppress checks="LineLength" files=".*\.java"/>
    <suppress checks="MissingJavadocMethod" files=".*\.java"/>
</suppressions>