# ============================================
# Database Credentials (ДОЛЖНЫ БЫТЬ ИЗМЕНЕНЫ!)
# ============================================
DB_USER_USER=user
DB_USER_PASS=CHANGE_ME_STRONG_PASSWORD
DB_EVENT_USER=event
DB_EVENT_PASS=CHANGE_ME_STRONG_PASSWORD
DB_REQUEST_USER=request
DB_REQUEST_PASS=CHANGE_ME_STRONG_PASSWORD
DB_COMMENT_USER=comment
DB_COMMENT_PASS=CHANGE_ME_STRONG_PASSWORD
DB_STATS_USER=stats
DB_STATS_PASS=CHANGE_ME_STRONG_PASSWORD

# ============================================
# Redis (ДОЛЖЕН БЫТЬ ИЗМЕНЕН!)
# ============================================
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# JWT Authentication (ДОЛЖЕН БЫТЬ ИЗМЕНЕН!)
# ============================================
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ============================================
# SSL/TLS
# ============================================
SSL_KEYSTORE_PATH=/etc/ssl/private/keystore.p12
SSL_KEYSTORE_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SSL_KEY_ALIAS=ewm

# ============================================
# Grafana
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# Feature Flags
# ============================================
FEATURE_RECOMMENDATIONS_ENABLED=true
FEATURE_NEW_UI_ENABLED=false
FEATURE_COMMENTS_MODERATION_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true

# ============================================
# Monitoring & Logging
# ============================================
ELASTIC_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KIBANA_PASSWORD=CHANGE_ME_STRONG_PASSWORD
LOGSTASH_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================
# External Services
# ============================================
SLACK_WEBHOOK_URL=CHANGE_ME
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME