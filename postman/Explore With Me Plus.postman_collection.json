        "type": "text/javascript",
        "packages": {},
        "exec": [
          "// Extract token from login response",
          "if (pm.response.code === 200 && pm.response.json().accessToken) {",
          "    pm.collectionVariables.set('access_token', pm.response.json().accessToken);",
          "}",
          "if (pm.response.code === 200 && pm.response.json().refreshToken) {",
          "    pm.collectionVariables.set('refresh_token', pm.response.json().refreshToken);",
          "}",
          "",
          "// Test response status",
          "pm.test('Status code is 200 or 201', function () {",
          "    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204]);",
          "});",
          "",
          "// Test response time",
          "pm.test('Response time is less than 1000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});",
          "",
          "// Test for valid JSON",
          "pm.test('Response is valid JSON', function () {",
          "    pm.response.to.be.json;",
          "});",
          "",
          "// Test error response",
          "if (pm.response.code >= 400) {",
          "    pm.test('Error response has message', function () {",
          "        const jsonData = pm.response.json();",
          "        pm.expect(jsonData).to.have.property('message');",
          "    });",
          "}"
        ]
      }
    }
