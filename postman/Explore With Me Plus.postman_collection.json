        {
          "name": "Get Event by ID (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetEvent($id: ID!) {\n  event(id: $id) {\n    id\n    title\n    annotation\n    description\n    eventDate\n    category {\n      id\n      name\n    }\n    initiator {\n      id\n      name\n    }\n    paid\n    participantLimit\n    confirmedRequests\n    rating\n    state\n  }\n}",
                "variables": "{\n  \"id\": 1\n}"
              }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            },
            "description": "Получение события через GraphQL"
          },
          "response": []
        },
        {
          "name": "Get Events with Filters (GraphQL)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetEvents(\n  $text: String,\n  $categories: [ID!],\n  $paid: Boolean,\n  $from: Int,\n  $size: Int\n) {\n  events(\n    text: $text,\n    categories: $categories,\n    paid: $paid,\n    from: $from,\n    size: $size\n  ) {\n    id\n    title\n    annotation\n    eventDate\n    category {\n      id\n      name\n    }\n    initiator {\n      id\n      name\n    }\n    rating\n    confirmedRequests\n  }\n}",
                "variables": "{\n  \"text\": \"concert\",\n  \"categories\": [1, 2],\n  \"paid\": false,\n  \"from\": 0,\n  \"size\": 10\n}"
              }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            },
            "description": "Получение событий с фильтрацией через GraphQL"
          },
          "response": []
        }
